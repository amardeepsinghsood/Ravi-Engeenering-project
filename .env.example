# == LLM Configuration ==
# We are using Gemini via @google/genai module
LLM_API_KEY=your_gemini_api_key_here

# == Server Configuration ==
PORT=3000

# == Email Setup (Nodemailer for sending Lead Summaries to Owner) ==
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_sending_email@gmail.com
SMTP_PASS=your_app_specific_password

# The email where the business owner receives the leads
OWNER_EMAIL=owner@raviengineering.com

# == (Optional) WhatsApp Alert Stub ==
WHATSAPP_API_KEY=your_whatsapp_api_key
OWNER_WHATSAPP=+91XXXXXXXXXX
